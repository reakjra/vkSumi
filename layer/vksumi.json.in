{
    "file_format_version": "1.0.0",
    "layer": {
        "name": "VK_LAYER_vksumi_color_grading",
        "type": "GLOBAL",
        "library_path": "@LIBRARY_PATH@",
        "api_version": "1.4.0",
        "implementation_version": "1",
        "description": "vkSumi runtime color grading (brightness, contrast, saturation, hue, gamma)",
        "functions": {
            "vkGetInstanceProcAddr": "vksumi_GetInstanceProcAddr",
            "vkGetDeviceProcAddr": "vksumi_GetDeviceProcAddr"
        },
        "enable_environment": {
            "ENABLE_VKSUMI": "1"
        },
        "disable_environment": {
            "DISABLE_VKSUMI": "1"
        }
    }
}
